{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pos/core/*": [
        "packages/core/src/*"
      ],
      "@pos/shared/*": [
        "packages/shared/src/*"
      ],
      "@pos/data/*": [
        "packages/data/src/*"
      ],
      "@pos/web/*": [
        "apps/web/src/*"
      ]
    }
  }
}
