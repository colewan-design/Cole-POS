{
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/app",     "destination": "/app.html"     },
    { "source": "/app/(.*)", "destination": "/app.html"    },
    { "source": "/",        "destination": "/index.html"   }
  ]
}
