{
  "experimentalServices": {
    "web": {
      "root": "apps/web",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "framework": "vite"
    }
  },
  "rewrites": [
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/app",     "destination": "/app.html"     },
    { "source": "/app/(.*)", "destination": "/app.html"    },
    { "source": "/",        "destination": "/index.html"   }
  ]
}
