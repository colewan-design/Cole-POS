rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userOrgId() { return userDoc().organizationId; }
    function isAdmin() { return signedIn() && userDoc().roleKey == 'admin'; }
    function isNewAccount() { return !exists(/databases/$(database)/documents/users/$(request.auth.uid)); }

    match /organizations/{orgId} {
      allow read: if signedIn();                 // any authenticated user resolves slug -> org
      allow create: if false;                     // provisioned out-of-band (console/seed script)
      // Only a signed-in user who doesn't yet have a profile doc (i.e. mid-registration)
      // may flip the flag, and only false -> true, once. Prevents other orgs' members from griefing it.
      allow update: if signedIn() && isNewAccount()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstAdminClaimed'])
        && resource.data.firstAdminClaimed == false
        && request.resource.data.firstAdminClaimed == true;

      match /stores/{storeId} {
        // pairingCode lives on this doc and is the storefront's de facto access
        // secret (see SCHEMA.md) — must not be readable by other orgs' staff.
        // Pairing-code lookup itself goes through resolve-store-code.ts (Admin
        // SDK, bypasses rules), so this stays org-scoped with no functional loss.
        allow read: if signedIn() && orgId == userOrgId();
        allow write: if false;
      }
      match /roles/{roleKey} {
        allow read: if signedIn() && orgId == userOrgId();
        allow write: if isAdmin() && orgId == userOrgId();
      }
      match /categories/{categoryId} {
        allow read: if true;                       // public storefront catalog
        allow write: if signedIn() && orgId == userOrgId();
      }
      match /products/{productId} {
        allow read: if true;                       // public storefront catalog
        allow write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/orders/{orderId} {
        allow read, write: if signedIn() && orgId == userOrgId();
        // Public order-tracking link: the doc ID is the capability token. Only
        // single-doc "get" is public — "list" stays staff-only, so orders can
        // never be browsed/enumerated by an outsider.
        allow get: if true;
        match /items/{itemId} {
          // The order ID is already the capability token for the parent doc's
          // public `get` above; a signed-out customer reading the line items
          // of an order they already know the ID of leaks nothing new. This
          // was previously staff-only, which broke the public tracking page —
          // getDocs() on this subcollection threw for anonymous visitors.
          allow get, list: if true;
          allow write: if signedIn() && orgId == userOrgId();
        }
      }
      match /stores/{storeId}/inventoryLevels/{productId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/inventoryAdjustments/{adjId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/shifts/{shiftId} {
        allow read, write: if signedIn() && orgId == userOrgId();
        match /cashMovements/{movementId} { allow read, write: if signedIn() && orgId == userOrgId(); }
      }
      // Idempotency guard: once written, a sync event can never be changed.
      match /stores/{storeId}/syncEvents/{eventId} {
        allow read, create: if signedIn() && orgId == userOrgId();
        allow update, delete: if false;
      }
    }

    // Version pointer the mobile app polls for its own update-available
    // indicator (Settings screen) — see apps/mobile/src/storefront/updateCheck.ts.
    // Public and read-only; the developer updates it by hand on each release.
    match /appReleases/{appId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || resource.data.organizationId == userOrgId());
      allow create: if signedIn() && uid == request.auth.uid && request.resource.data.organizationId is string;
      allow update: if signedIn() && (
          // Self-service is limited to display name — status is an admin-only
          // lever (e.g. deactivating an account) and must not be self-editable,
          // or a disabled user could just flip themselves back to active.
          (uid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName']))
          || (isAdmin() && resource.data.organizationId == userOrgId()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roleKey', 'status']))
        );
      allow delete: if false;
    }
  }
}
