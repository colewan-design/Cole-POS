rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function userOrgId() { return userDoc().organizationId; }
    function isAdmin() { return signedIn() && userDoc().roleKey == 'admin'; }
    function isNewAccount() { return !exists(/databases/$(database)/documents/users/$(request.auth.uid)); }

    match /organizations/{orgId} {
      allow read: if signedIn();                 // any authenticated user resolves slug -> org
      allow create: if false;                     // provisioned out-of-band (console/seed script)
      // Only a signed-in user who doesn't yet have a profile doc (i.e. mid-registration)
      // may flip the flag, and only false -> true, once. Prevents other orgs' members from griefing it.
      allow update: if signedIn() && isNewAccount()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstAdminClaimed'])
        && resource.data.firstAdminClaimed == false
        && request.resource.data.firstAdminClaimed == true;

      match /stores/{storeId} {
        allow read: if signedIn();
        allow write: if false;
      }
      match /roles/{roleKey} {
        allow read: if signedIn() && orgId == userOrgId();
        allow write: if isAdmin() && orgId == userOrgId();
      }
      match /categories/{categoryId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /products/{productId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/orders/{orderId} {
        allow read, write: if signedIn() && orgId == userOrgId();
        match /items/{itemId} { allow read, write: if signedIn() && orgId == userOrgId(); }
      }
      match /stores/{storeId}/inventoryLevels/{productId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/inventoryAdjustments/{adjId} {
        allow read, write: if signedIn() && orgId == userOrgId();
      }
      match /stores/{storeId}/shifts/{shiftId} {
        allow read, write: if signedIn() && orgId == userOrgId();
        match /cashMovements/{movementId} { allow read, write: if signedIn() && orgId == userOrgId(); }
      }
      // Idempotency guard: once written, a sync event can never be changed.
      match /stores/{storeId}/syncEvents/{eventId} {
        allow read, create: if signedIn() && orgId == userOrgId();
        allow update, delete: if false;
      }
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || resource.data.organizationId == userOrgId());
      allow create: if signedIn() && uid == request.auth.uid && request.resource.data.organizationId is string;
      allow update: if signedIn() && (
          (uid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'status']))
          || (isAdmin() && resource.data.organizationId == userOrgId()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['roleKey']))
        );
      allow delete: if false;
    }
  }
}
